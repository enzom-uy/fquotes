{
    "name": "fquotes",
    "compatibility_date": "2026-02-21",
    "compatibility_flags": [
        "nodejs_compat",
        "disable_nodejs_process_v2"
    ],
    "pages_build_output_dir": "./dist",
    "vars": {
        "PUBLIC_FRONTEND_URL": "https://fquotes.pages.dev",
        "PUBLIC_BACKEND_URL": "https://bquotes-production.up.railway.app/api"
    }
}
