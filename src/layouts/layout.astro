---
import '@/styles/globals.css'
import Navbar from '@/components/navbar.astro'

interface Props {
  title?: string
  showNavbar?: boolean
}

const { title = 'QuoteKeeper', showNavbar = true } = Astro.props

// Get user and session from middleware
const user = Astro.locals.user
const session = Astro.locals.session

// Only show navbar if user is authenticated and showNavbar is true
const shouldShowNavbar = showNavbar && session && user
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <title>{title}</title>
  </head>
  <body>
    {shouldShowNavbar && <Navbar user={user} />}
    <slot />
  </body>
</html>
