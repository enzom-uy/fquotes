---
import { Github, ExternalLink } from 'lucide-react'
---

<footer class="w-full border-t border-background-muted bg-background mt-auto">
  <div class="container mx-auto px-4 py-6">
    <div class="flex flex-col sm:flex-row items-center justify-between gap-4 text-sm text-foreground-muted">
      <!-- Created by -->
      <div class="flex items-center gap-1.5">
        <span>Created with</span>
        <span class="text-danger">♥</span>
        <span>by</span>
        <a
          href="https://github.com/enzom-uy"
          target="_blank"
          rel="noopener noreferrer"
          class="text-foreground hover:text-primary transition-colors font-medium inline-flex items-center gap-1"
        >
          <Github className="h-4 w-4" />
          enzom-uy
          <ExternalLink className="h-3.5 w-3.5" />
        </a>
      </div>

      <!-- Powered by OpenLibrary -->
      <div class="flex items-center gap-1.5">
        <span>Powered by</span>
        <a
          href="https://openlibrary.org/"
          target="_blank"
          rel="noopener noreferrer"
          class="text-foreground hover:text-primary transition-colors font-medium inline-flex items-center gap-1"
        >
          OpenLibrary
          <ExternalLink className="h-3.5 w-3.5" />
        </a>
      </div>
    </div>
  </div>
</footer>
