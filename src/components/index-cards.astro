---
import { getTranslations, type Locale } from '@/i18n'

const locale = (Astro.currentLocale || 'en') as Locale
const t = getTranslations(locale)

const elements = [
  {
    icon: "📸",
    title: t.home.features.capture.title,
    description: t.home.features.capture.description,
  },
  {
    icon: "✂️",
    title: t.home.features.crop.title,
    description: t.home.features.crop.description,
  },
  {
    icon: "🤖",
    title: t.home.features.recognize.title,
    description: t.home.features.recognize.description,
  },
];
---

<div class="flex sm:flex-row flex-col gap-4">
  {elements.map((element) => (
    <div
      class="bg-background-elevated flex flex-col items-center text-center p-4 rounded-lg border-border border gap-2"
    >
      <div class="flex flex-col gap-2">
        <span class="text-3xl">{element.icon}</span>
        <h2 class="font-semibold">{element.title}</h2>
      </div>
      <p class="text-sm md:max-w-[16ch]">{element.description}</p>
    </div>
  ))}
</div>
