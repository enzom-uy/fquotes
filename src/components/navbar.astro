---
import { NavbarMenu } from "./navbar-menu";
import { UserDropdown } from "./user-dropdown";

interface Props {
  user?: {
    name: string;
    email: string;
    image?: string | null;
  } | null;
}

const { user } = Astro.props;
const currentPath = Astro.url.pathname;
---

<header class="sticky top-0 z-50 border-b border-border bg-background-elevated/95 backdrop-blur-sm">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="flex items-center justify-between h-16">
      {/* Logo */}
      <a href="/" class="flex items-center gap-3 hover:opacity-90 transition-opacity group">
        <div class="w-10 h-10 bg-gradient-to-br from-primary to-accent rounded-xl flex items-center justify-center text-2xl group-hover:scale-105 transition-transform">
          📚
        </div>
        <span class="text-xl font-semibold hidden sm:block">QuoteKeeper</span>
      </a>

      {/* Desktop Navigation */}
      {user && (
        <nav class="hidden md:flex items-center gap-1">
          <a
            href="/"
            class={`
              flex items-center gap-2 px-4 py-2 rounded-lg text-sm font-medium transition-all
              ${currentPath === '/' 
                ? 'bg-primary/10 text-primary' 
                : 'text-foreground-muted hover:text-foreground hover:bg-background-muted'
              }
            `}
          >
            <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M14.5 4h-5L7 7H4a2 2 0 0 0-2 2v9a2 2 0 0 0 2 2h16a2 2 0 0 0 2-2V9a2 2 0 0 0-2-2h-3l-2.5-3z"></path>
              <circle cx="12" cy="13" r="3"></circle>
            </svg>
            Capture
          </a>
        </nav>
      )}

      {/* Right Side */}
      <div class="flex items-center gap-3">
        {user ? (
          <>
            {/* User Dropdown - Desktop */}
            <div class="hidden md:block">
              <UserDropdown 
                userName={user.name}
                userImage={user.image}
                client:load 
              />
            </div>

            {/* Mobile Menu Button */}
            <NavbarMenu 
              currentPath={currentPath} 
              userName={user.name}
              userImage={user.image}
              client:load 
            />
          </>
        ) : (
          <a
            href="/"
            class="px-4 py-2 text-sm font-medium text-foreground-muted hover:text-foreground transition-colors"
          >
            Sign In
          </a>
        )}
      </div>
    </div>
  </div>
</header>
