---
import { NavbarMenu } from "./navbar-menu";
import { SignOutButton } from "./sign-out-button";

interface Props {
  user?: {
    name: string;
    email: string;
    image?: string | null;
  } | null;
}

const { user } = Astro.props;
const currentPath = Astro.url.pathname;
---

<header class="sticky top-0 z-50 border-b border-border bg-background-elevated/95 backdrop-blur-sm">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="flex items-center justify-between h-16">
      {/* Logo */}
      <a href="/" class="flex items-center gap-3 hover:opacity-90 transition-opacity group">
        <div class="w-10 h-10 bg-gradient-to-br from-primary to-accent rounded-xl flex items-center justify-center text-2xl group-hover:scale-105 transition-transform">
          📚
        </div>
        <span class="text-xl font-semibold hidden sm:block">QuoteKeeper</span>
      </a>

      {/* Desktop Navigation */}
      {user && (
        <nav class="hidden md:flex items-center gap-1">
          <a
            href="/"
            class={`
              flex items-center gap-2 px-4 py-2 rounded-lg text-sm font-medium transition-all
              ${currentPath === '/' 
                ? 'bg-primary/10 text-primary' 
                : 'text-foreground-muted hover:text-foreground hover:bg-background-muted'
              }
            `}
          >
            <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M14.5 4h-5L7 7H4a2 2 0 0 0-2 2v9a2 2 0 0 0 2 2h16a2 2 0 0 0 2-2V9a2 2 0 0 0-2-2h-3l-2.5-3z"></path>
              <circle cx="12" cy="13" r="3"></circle>
            </svg>
            Capture
          </a>
          
          <a
            href="/quotes"
            class={`
              flex items-center gap-2 px-4 py-2 rounded-lg text-sm font-medium transition-all
              ${currentPath === '/quotes' 
                ? 'bg-primary/10 text-primary' 
                : 'text-foreground-muted hover:text-foreground hover:bg-background-muted'
              }
            `}
          >
            <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M4 19.5v-15A2.5 2.5 0 0 1 6.5 2H20v20H6.5a2.5 2.5 0 0 1 0-5H20"></path>
              <path d="m9 9.5 2 2 4-4"></path>
            </svg>
            My Quotes
          </a>
        </nav>
      )}

      {/* Right Side */}
      <div class="flex items-center gap-3">
        {user ? (
          <>
            {/* Sign Out Button - Desktop */}
            <div class="hidden md:block">
              <SignOutButton client:load />
            </div>

            {/* Profile Button - Desktop */}
            <a
              href="/profile"
              class="hidden md:flex items-center gap-2 px-3 py-2 rounded-lg hover:bg-background-muted transition-colors group"
              title={user.name}
            >
              {user.image ? (
                <img
                  src={user.image}
                  alt={user.name}
                  class="w-8 h-8 rounded-full object-cover border-2 border-border group-hover:border-primary transition-colors"
                />
              ) : (
                <div class="w-8 h-8 rounded-full bg-gradient-to-br from-primary to-accent flex items-center justify-center text-background font-semibold text-sm">
                  {user.name.charAt(0).toUpperCase()}
                </div>
              )}
              <span class="text-sm font-medium text-foreground-muted group-hover:text-foreground transition-colors">
                {user.name.split(' ')[0]}
              </span>
            </a>

            {/* Mobile Menu Button */}
            <NavbarMenu 
              currentPath={currentPath} 
              userName={user.name}
              userImage={user.image}
              client:load 
            />
          </>
        ) : (
          <a
            href="/"
            class="px-4 py-2 text-sm font-medium text-foreground-muted hover:text-foreground transition-colors"
          >
            Sign In
          </a>
        )}
      </div>
    </div>
  </div>
</header>
