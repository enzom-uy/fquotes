---
import { QuoteData } from "@/components/quote-card"
import { getLocalizedPath, type Locale, t } from "@/i18n"
import Layout from "@/layouts/layout.astro"
import { QuoteDetailView } from "@/components/quote-detail-view"

const { id } = Astro.params
const locale = (Astro.currentLocale || 'en') as Locale

// Use backend URL directly in SSR context
const BACKEND_URL = import.meta.env.PUBLIC_BACKEND_URL || 'http://localhost:5000/api'
const cookieHeader = Astro.request.headers.get('cookie') || ''

// Fetch quote from backend
let quote: QuoteData | null = null
let quoteAuthor: { id: string; name: string; image: string | null } | null = null
let errorMessage = ""

try {
  const quoteRes = await fetch(`${BACKEND_URL}/quotes/${id}`, {
    headers: { cookie: cookieHeader }
  })
  
  if (quoteRes.ok) {
    quote = await quoteRes.json()
    
    // Fetch quote author information
    if (quote?.userId) {
      try {
        const authorRes = await fetch(`${BACKEND_URL}/user?id=${quote.userId}`, {
          headers: { cookie: cookieHeader }
        })
        
        if (authorRes.ok) {
          const authorData = await authorRes.json()
          quoteAuthor = {
            id: authorData.id,
            name: authorData.name,
            image: authorData.image || null
          }
        }
      } catch (err) {
        // Silent fail - author data is optional
      }
    }
  } else if (quoteRes.status === 404) {
    errorMessage = t(locale, 'quote.quoteNotFound')
  } else {
    errorMessage = t(locale, 'errors.generic')
  }
} catch (error: any) {
  errorMessage = t(locale, 'errors.generic')
}

const { session } = Astro.locals
const userId = session?.userId
const userIsOwner = userId && quote ? userId === quote.userId : false

// Redirect if quote is private and user is not the owner
if (quote && !quote.isPublic && !userIsOwner) {
  return Astro.redirect(getLocalizedPath('/', locale))
}

const pageTitle = quote 
  ? `${quote.book?.title || t(locale, 'common.quote')} - ${t(locale, 'common.appName')}`
  : `${t(locale, 'common.quote')} - ${t(locale, 'common.appName')}`
---

<Layout title={pageTitle}>
  {errorMessage ? (
    <div class="min-h-screen flex items-center justify-center">
      <div class="text-center">
        <h1 class="text-3xl font-bold mb-4">{errorMessage}</h1>
        <a 
          href={getLocalizedPath('/', locale)}
          class="text-primary hover:underline"
        >
          {t(locale, 'quote.backToQuotes')}
        </a>
      </div>
    </div>
  ) : quote ? (
    <QuoteDetailView 
      quote={quote} 
      quoteAuthor={quoteAuthor}
      locale={locale} 
      userIsOwner={userIsOwner}
      client:only="react"
    />
  ) : null}
</Layout>
