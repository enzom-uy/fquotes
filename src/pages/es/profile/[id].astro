---
import { getLocalizedPath, getTranslations, type Locale } from "@/i18n"
import Layout from "@/layouts/layout.astro"

const { id } = Astro.params
const locale = (Astro.currentLocale || 'en') as Locale
const t = getTranslations(locale)

// TODO: Implement user profile page
// This is a placeholder for now
---

<Layout title={`${t.nav.profile} - ${t.common.appName}`}>
  <div class="container mx-auto px-4 py-8">
    <div class="max-w-2xl mx-auto">
      <h1 class="text-3xl font-bold mb-4">{t.nav.profile}</h1>
      <p class="text-foreground-muted">User ID: {id}</p>
      <p class="text-foreground-muted mt-4">This profile page is under construction.</p>
    </div>
  </div>
</Layout>
