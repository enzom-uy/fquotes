---
import Layout from '@/layouts/layout.astro';
import { QuotesManager } from '@/components/quotes-manager';
import { getTranslations, type Locale, getLocalizedPath } from '@/i18n';
import { fetchUserQuotes, calculatePagination } from '@/lib/fetch-quotes';

export const prerender = false;

const user = Astro.locals.user;
const session = Astro.locals.session;

const locale = (Astro.currentLocale || 'en') as Locale;
const t = getTranslations(locale);

if (!session) {
  return Astro.redirect(getLocalizedPath('/', locale));
}

const PER_PAGE = 10;
const currentPage = Math.max(1, Number(Astro.url.searchParams.get('page')) || 1);

// Fetch quotes using the reusable function
const { quotes, totalQuotes, error: fetchError } = await fetchUserQuotes({
  userId: user!.id,
  perPage: PER_PAGE,
  page: currentPage - 1, // Backend expects 0-indexed pages
  cookieHeader: Astro.request.headers.get('cookie') || '',
});

// Calculate pagination metadata
const { totalPages, showingFrom, showingTo, pageNumbers } = calculatePagination(
  totalQuotes,
  currentPage,
  PER_PAGE
);
---

<Layout title={`${t.quotes.title} - ${t.common.appName}`}>
  <main class="max-w-6xl mx-auto w-full px-4 py-8">
    <div class="space-y-6">
      <!-- Header -->
      <div class="flex flex-col gap-4">
        <div>
          <h1 class="text-3xl font-bold">{t.quotes.title}</h1>
        </div>

        <!-- QuotesManager: search, grid, pagination, delete all in one React island -->
        <QuotesManager
          client:load
          userId={user!.id}
          quotes={quotes}
          pagination={{
            currentPage,
            totalPages,
            totalQuotes,
            showingFrom,
            showingTo,
            pageNumbers,
          }}
          fetchError={fetchError}
          locale={locale}
        />
      </div>
    </div>
  </main>
</Layout>
