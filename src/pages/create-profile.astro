---
import Layout from '@/layouts/layout.astro'
import { CreateProfileForm } from '@/components/create-profile-form'

const { user } = Astro.locals

if (!user) {
    return Astro.redirect('/')
}

const createdAt = new Date(user.createdAt).getTime()
const updatedAt = new Date(user.updatedAt).getTime()
const THRESHOLD_MS = 1000
const profileCompleted = (updatedAt - createdAt) > THRESHOLD_MS
if (profileCompleted) {
    return Astro.redirect('/profile')
}

---

<Layout title="Create Profile - QuoteKeeper">
  <div class="min-h-screen flex flex-col items-center gap-8 justify-center px-6 py-12">
    <div class="text-center">
      <h1 class="text-4xl font-semibold mb-2">Create Your Profile</h1>
      <p class="text-foreground-subtle">
        Complete your profile to get started with QuoteKeeper
      </p>
    </div>
        <CreateProfileForm
            email={user.email}
            name={user.name}
            profilePic={user.image || undefined}
          client:load
        />
  </div>
</Layout>
