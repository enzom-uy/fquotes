---
export const prerender = false
import Layout from '@/layouts/layout.astro'
import { CreateProfileForm } from '@/components/auth/create-profile-form'
import { getTranslations, type Locale, getLocalizedPath } from '@/i18n'

const { user } = Astro.locals

const locale = (Astro.currentLocale || 'en') as Locale
const t = getTranslations(locale)

if (!user) {
    return Astro.redirect(getLocalizedPath('/', locale))
}

if (user.profileCompleted) {
    return Astro.redirect(getLocalizedPath('/profile', locale))
}

---

<Layout title={`${t.createProfile.title} - ${t.common.appName}`}>
  <div class="min-h-screen flex flex-col items-center gap-8 justify-center px-6 py-12">
    <div class="text-center">
      <h1 class="text-4xl font-semibold mb-2">{t.createProfile.title}</h1>
      <p class="text-foreground-subtle">
        {t.createProfile.subtitle}
      </p>
    </div>
        <CreateProfileForm
            email={user.email}
            name={user.name}
            profilePic={user.image || undefined}
            locale={locale}
          client:idle
        />
  </div>
</Layout>
