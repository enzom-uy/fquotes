---
import Layout from '@/layouts/layout.astro'
import { BookOpen } from 'lucide-react'
import { ProfileDataComponent } from '@/components/profile-data'

export const prerender = false

const user = Astro.locals.user
const session = Astro.locals.session

if (!session || !user) {
  return Astro.redirect('/')
}

const BACKEND_URL = import.meta.env.PUBLIC_BACKEND_URL
const cookieHeader = Astro.request.headers.get('cookie') || ''

interface QuoteResponse {
  id: string
  text: string
  chapter: string | null
  isPublic: boolean
  isFavorite: boolean
  tags: string[] | null
  createdAt: string
  bookId: string
  book: {
    id: string
    title: string
    authorName: string | null
    coverUrl: string | null
  } | null
}

interface PaginatedResponse {
  data: QuoteResponse[]
  count: number
  page: number
  perPage: number
}

let quoteCount = 0
let favoriteQuotes: QuoteResponse[] = []
let recentQuotes: QuoteResponse[] = []
let error = false

try {
    console.log('starting fetch.')
  const [countRes, favoritesRes, recentRes] = await Promise.all([
    fetch(`${BACKEND_URL}/quotes/${user.id}/count`, {
      headers: { cookie: cookieHeader },
    }),
    fetch(`${BACKEND_URL}/quotes/${user.id}/favorites`, {
      headers: { cookie: cookieHeader },
    }),
    fetch(`${BACKEND_URL}/quotes/${user.id}?perPage=6&page=0`, {
      headers: { cookie: cookieHeader },
    }),
  ])

  console.log(countRes)

  if (countRes.ok) {
    quoteCount = await countRes.json()
  }
  if (favoritesRes.ok) {
    favoriteQuotes = await favoritesRes.json()
  }
  if (recentRes.ok) {
    const result: PaginatedResponse = await recentRes.json()
    recentQuotes = result.data
  }
} catch (err) {
  console.error('Failed to fetch profile data:', err)
  error = true
}
---

<Layout title="Profile - QuoteKeeper">
  <main class="max-w-4xl mx-auto w-full px-4 py-8">
    <div class="space-y-8">
      <!-- Profile with stats and quotes (React island) -->
      <ProfileDataComponent
        client:load
        user={{
          name: user.name,
          email: user.email,
          image: user.image || null,
        }}
        initialQuoteCount={quoteCount ? quoteCount : undefined}
        initialFavoriteQuotes={favoriteQuotes ? favoriteQuotes : undefined}
        initialRecentQuotes={recentQuotes ? recentQuotes : undefined}
        userId={user.id}
        error={error && error}
      />

      <!-- Empty State -->
      {quoteCount === 0 && (
        <div class="bg-background-elevated border border-border rounded-xl p-12 text-center">
          <BookOpen size={48} className="mx-auto text-foreground-muted mb-4" />
          <h2 class="text-xl font-semibold mb-2">No quotes yet</h2>
          <p class="text-foreground-muted mb-6">Start capturing quotes from your favorite books!</p>
          <a
            href="/"
            class="inline-flex items-center gap-2 px-6 py-3 bg-primary text-background font-semibold rounded-lg hover:opacity-90 transition-opacity"
          >
            Capture a Quote
          </a>
        </div>
      )}
    </div>
  </main>
</Layout>
