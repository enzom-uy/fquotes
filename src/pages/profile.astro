---
import Layout from '@/layouts/layout.astro'
import { BookOpen, Star, Globe, Lock, Heart, Share2, Trash2, Calendar } from 'lucide-react'

export const prerender = false

const user = Astro.locals.user
const session = Astro.locals.session

if (!session || !user) {
  return Astro.redirect('/')
}

const BACKEND_URL = import.meta.env.PUBLIC_BACKEND_URL || 'http://localhost:5000/api'
const cookieHeader = Astro.request.headers.get('cookie') || ''

interface QuoteResponse {
  id: string
  text: string
  chapter: string | null
  isPublic: boolean
  isFavorite: boolean
  tags: string[] | null
  createdAt: string
  bookId: string
  book: {
    id: string
    title: string
    authorName: string | null
    coverUrl: string | null
  } | null
}

interface PaginatedResponse {
  data: QuoteResponse[]
  count: number
  page: number
  perPage: number
}

// Fetch all data in parallel
let quoteCount = 0
let favoriteQuotes: QuoteResponse[] = []
let recentQuotes: QuoteResponse[] = []

try {
  const [countRes, favoritesRes, recentRes] = await Promise.all([
    fetch(`${BACKEND_URL}/quotes/${user.id}/count`, {
      headers: { cookie: cookieHeader },
    }),
    fetch(`${BACKEND_URL}/quotes/${user.id}/favorites`, {
      headers: { cookie: cookieHeader },
    }),
    fetch(`${BACKEND_URL}/quotes/${user.id}?perPage=6&page=0`, {
      headers: { cookie: cookieHeader },
    }),
  ])

  if (countRes.ok) {
    quoteCount = await countRes.json()
  }
  if (favoritesRes.ok) {
    favoriteQuotes = await favoritesRes.json()
  }
  if (recentRes.ok) {
    const result: PaginatedResponse = await recentRes.json()
    recentQuotes = result.data
  }
} catch (error) {
  console.error('Failed to fetch profile data:', error)
}

const formatDate = (dateString: string) => {
  const date = new Date(dateString)
  return date.toLocaleDateString('en-US', {
    month: 'short',
    day: 'numeric',
    year: 'numeric',
  })
}
---

<Layout title="Profile - QuoteKeeper">
  <main class="max-w-4xl mx-auto w-full px-4 py-8">
    <div class="space-y-8">

      <!-- Profile Card -->
      <div class="bg-background-elevated border border-border rounded-2xl overflow-hidden">
        <div class="flex items-center gap-5 p-6">
          {user.image ? (
            <img
              src={user.image}
              alt={user.name}
              class="w-20 h-20 rounded-full object-cover border-3 border-primary flex-shrink-0"
              referrerpolicy="no-referrer"
            />
          ) : (
            <div class="w-20 h-20 rounded-full bg-gradient-to-br from-primary to-accent flex items-center justify-center text-background font-bold text-2xl flex-shrink-0">
              {user.name.charAt(0).toUpperCase()}
            </div>
          )}
          <div class="min-w-0">
            <h1 class="text-2xl font-bold truncate">{user.name}</h1>
            <p class="text-sm text-foreground-muted truncate">{user.email}</p>
          </div>
        </div>

        <div class="border-t border-border" />

        <!-- Stats -->
        <div class="p-6">
          <div class="grid grid-cols-2 gap-4">
            <div class="flex flex-col items-center gap-2 p-4 bg-background-muted rounded-xl">
              <BookOpen size={24} className="text-primary" />
              <div class="text-center">
                <div class="text-2xl font-bold">{quoteCount}</div>
                <div class="text-xs text-foreground-subtle">Total Quotes</div>
              </div>
            </div>
            <div class="flex flex-col items-center gap-2 p-4 bg-background-muted rounded-xl">
              <Star size={24} className="text-warning" />
              <div class="text-center">
                <div class="text-2xl font-bold">{favoriteQuotes.length}</div>
                <div class="text-xs text-foreground-subtle">Favorites</div>
              </div>
            </div>
          </div>
        </div>
      </div>

      <!-- Favorite Quotes Section -->
      {favoriteQuotes.length > 0 && (
        <div>
          <h2 class="text-xl font-semibold mb-4 flex items-center gap-2">
            <Star size={20} className="text-warning" />
            Favorite Quotes
          </h2>
          <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
            {favoriteQuotes.map((quote) => (
              <div class="bg-background-elevated border border-border-hover rounded-xl p-5 hover:border-primary transition-colors border-l-[3px] border-l-warning">
                <div class="flex flex-col gap-3">
                  <!-- Quote text -->
                  <div class="flex items-start justify-between gap-3">
                    <p class="text-sm leading-relaxed italic flex-1">
                      &ldquo;{quote.text}&rdquo;
                    </p>
                    <Star size={16} fill="currentColor" className="text-warning flex-shrink-0 mt-0.5" />
                  </div>

                  <!-- Book & author -->
                  {quote.book && (
                    <div class="flex flex-col gap-1">
                      <span class="text-sm font-medium text-foreground-muted truncate">
                        {quote.book.title}{quote.chapter ? `, ${quote.chapter}` : ''}
                      </span>
                      {quote.book.authorName && (
                        <span class="text-xs text-foreground-subtle truncate">
                          by {quote.book.authorName}
                        </span>
                      )}
                    </div>
                  )}

                  <!-- Visibility + Actions -->
                  <div class="flex items-center justify-between pt-3 border-t border-border">
                    <div class="flex items-center gap-2 text-xs text-foreground-subtle">
                      {quote.isPublic ? (
                        <Globe size={14} className="text-success" />
                      ) : (
                        <Lock size={14} className="text-foreground-subtle" />
                      )}
                      <span>{quote.isPublic ? 'Public' : 'Private'}</span>
                    </div>
                    <div class="flex items-center gap-1">
                      {/* TODO: Implement favorite toggle in the backend (PATCH /quotes/:id/favorite) */}
                      <button
                        class="p-1.5 rounded-md text-foreground-muted hover:bg-background-muted hover:text-warning transition-colors"
                        title="Unfavorite"
                      >
                        <Heart size={14} />
                      </button>
                      {/* TODO: Implement share functionality */}
                      <button
                        class="p-1.5 rounded-md text-foreground-muted hover:bg-background-muted hover:text-primary transition-colors"
                        title="Share"
                      >
                        <Share2 size={14} />
                      </button>
                      {/* TODO: Implement delete quote in the backend (DELETE /quotes/:id) */}
                      <button
                        class="p-1.5 rounded-md text-foreground-muted hover:bg-danger/10 hover:text-danger transition-colors"
                        title="Delete"
                      >
                        <Trash2 size={14} />
                      </button>
                    </div>
                  </div>
                </div>
              </div>
            ))}
          </div>
        </div>
      )}

      <!-- Recent Quotes Section -->
      {recentQuotes.length > 0 && (
        <div>
          <div class="flex items-center justify-between mb-4">
            <h2 class="text-xl font-semibold flex items-center gap-2">
              <BookOpen size={20} className="text-primary" />
              Recent Quotes
            </h2>
            <a
              href="/quotes"
              class="text-sm text-primary hover:underline transition-colors"
            >
              View all &rarr;
            </a>
          </div>
          <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
            {recentQuotes.map((quote) => (
              <div class="bg-background-elevated border border-border rounded-xl p-5 hover:border-primary transition-colors">
                <div class="flex flex-col gap-3">
                  <!-- Quote text -->
                  <div class="flex items-start justify-between gap-3">
                    <p class="text-sm leading-relaxed italic flex-1">
                      &ldquo;{quote.text}&rdquo;
                    </p>
                    {quote.isFavorite && (
                      <Star size={16} fill="currentColor" className="text-warning flex-shrink-0 mt-0.5" />
                    )}
                  </div>

                  <!-- Book & author -->
                  {quote.book && (
                    <div class="flex flex-col gap-1">
                      <span class="text-sm font-medium text-foreground-muted truncate">
                        {quote.book.title}{quote.chapter ? `, ${quote.chapter}` : ''}
                      </span>
                      {quote.book.authorName && (
                        <span class="text-xs text-foreground-subtle truncate">
                          by {quote.book.authorName}
                        </span>
                      )}
                    </div>
                  )}

                  <!-- Footer: date + visibility + actions -->
                  <div class="flex items-center justify-between pt-3 border-t border-border">
                    <div class="flex items-center gap-3 text-xs text-foreground-subtle">
                      <div class="flex items-center gap-1">
                        <Calendar size={12} />
                        <span>{formatDate(quote.createdAt)}</span>
                      </div>
                      <div class="flex items-center gap-1">
                        {quote.isPublic ? (
                          <Globe size={12} className="text-success" />
                        ) : (
                          <Lock size={12} className="text-foreground-subtle" />
                        )}
                      </div>
                    </div>
                    <div class="flex items-center gap-1">
                      {/* TODO: Implement favorite toggle in the backend (PATCH /quotes/:id/favorite) */}
                      <button
                        class="p-1.5 rounded-md text-foreground-muted hover:bg-background-muted hover:text-warning transition-colors"
                        title={quote.isFavorite ? 'Unfavorite' : 'Favorite'}
                      >
                        <Heart size={14} />
                      </button>
                      {/* TODO: Implement share functionality */}
                      <button
                        class="p-1.5 rounded-md text-foreground-muted hover:bg-background-muted hover:text-primary transition-colors"
                        title="Share"
                      >
                        <Share2 size={14} />
                      </button>
                      {/* TODO: Implement delete quote in the backend (DELETE /quotes/:id) */}
                      <button
                        class="p-1.5 rounded-md text-foreground-muted hover:bg-danger/10 hover:text-danger transition-colors"
                        title="Delete"
                      >
                        <Trash2 size={14} />
                      </button>
                    </div>
                  </div>
                </div>
              </div>
            ))}
          </div>
        </div>
      )}

      <!-- Empty State -->
      {quoteCount === 0 && (
        <div class="bg-background-elevated border border-border rounded-xl p-12 text-center">
          <BookOpen size={48} className="mx-auto text-foreground-muted mb-4" />
          <h2 class="text-xl font-semibold mb-2">No quotes yet</h2>
          <p class="text-foreground-muted mb-6">Start capturing quotes from your favorite books!</p>
          <a
            href="/"
            class="inline-flex items-center gap-2 px-6 py-3 bg-primary text-background font-semibold rounded-lg hover:opacity-90 transition-opacity"
          >
            Capture a Quote
          </a>
        </div>
      )}

    </div>
  </main>
</Layout>
