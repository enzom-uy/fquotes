---
import Layout from '@/layouts/layout.astro'
import { ProfileDataComponent } from '@/components/profile/profile-data'
import { getTranslations, type Locale, getLocalizedPath } from '@/i18n'

export const prerender = false

const user = Astro.locals.user
const session = Astro.locals.session

const locale = (Astro.currentLocale || 'en') as Locale
const t = getTranslations(locale)

if (!session || !user) {
  return Astro.redirect(getLocalizedPath('/', locale))
}

// Call backend directly in SSR context (fetch needs absolute URLs server-side)
const BACKEND_URL = import.meta.env.PUBLIC_BACKEND_URL || 'http://localhost:5000/api'
const cookieHeader = Astro.request.headers.get('cookie') || ''

interface QuoteResponse {
  id: string
  text: string
  chapter: string | null
  isPublic: boolean
  isFavorite: boolean
  tags: string[] | null
  createdAt: string
  bookId: string
  userId: string
  book: {
    id: string
    title: string
    authorName: string | null
    coverUrl: string | null
  } | null
}

interface PaginatedResponse {
  data: QuoteResponse[]
  count: number
  page: number
  perPage: number
}

let quoteCount = 0
let favoriteQuotes: QuoteResponse[] = []
let recentQuotes: QuoteResponse[] = []
let error = false

try {
  const [countRes, favoritesRes, recentRes] = await Promise.all([
    fetch(`${BACKEND_URL}/quotes/user/${user.id}/count`, {
      headers: { cookie: cookieHeader },
    }),
    fetch(`${BACKEND_URL}/quotes/user/${user.id}/favorites`, {
      headers: { cookie: cookieHeader },
    }),
    fetch(`${BACKEND_URL}/quotes/user/${user.id}?perPage=6&page=0`, {
      headers: { cookie: cookieHeader },
    }),
  ])

  if (countRes.ok) {
    quoteCount = await countRes.json()
  }
  if (favoritesRes.ok) {
    favoriteQuotes = await favoritesRes.json()
  }
  if (recentRes.ok) {
    const result: PaginatedResponse = await recentRes.json()
    recentQuotes = result.data
  }
} catch (err) {
  error = true
}
---

<Layout title={`${t.profile.title} - ${t.common.appName}`}>
  <main class="max-w-4xl mx-auto w-full px-4 py-8">
    <div class="space-y-8">
      <!-- Profile with stats and quotes (React island) -->
      <ProfileDataComponent
        client:load
        user={{
          name: user.name,
          email: user.email,
          image: user.image || null,
        }}
        initialQuoteCount={error ? undefined : quoteCount}
        initialFavoriteQuotes={error ? undefined : (favoriteQuotes.length > 0 ? favoriteQuotes : [])}
        initialRecentQuotes={recentQuotes.length > 0 ? recentQuotes : []}
        userId={user.id}
        error={error}
        locale={locale}
      />

      <!-- Empty State -->
      {quoteCount === 0 && (
        <div class="bg-background-elevated border border-border rounded-xl p-12 text-center">
          <svg xmlns="http://www.w3.org/2000/svg" width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="mx-auto text-foreground-muted mb-4">
            <path d="M2 3h6a4 4 0 0 1 4 4v14a3 3 0 0 0-3-3H2z"></path>
            <path d="M22 3h-6a4 4 0 0 0-4 4v14a3 3 0 0 1 3-3h7z"></path>
          </svg>
          <h2 class="text-xl font-semibold mb-2">{t.profile.noQuotes}</h2>
          <p class="text-foreground-muted mb-6">{t.profile.noQuotesDescription}</p>
          <a
            href={getLocalizedPath('/', locale)}
            class="inline-flex items-center gap-2 px-6 py-3 bg-primary text-background font-semibold rounded-lg hover:opacity-90 transition-opacity"
          >
            {t.quotes.captureQuote}
          </a>
        </div>
      )}
    </div>
  </main>
</Layout>
