---
import Layout from '@/layouts/layout.astro'
import Logo from '@/components/logo.astro'
import IndexCards from '@/components/index-cards.astro'
import { GoogleSignInButton } from '@/components/auth/google-sign-in-button'
import { CaptureImage } from '@/components/capture/capture-image'
import { LanguageSwitcher } from '@/components/language-switcher'
import { getTranslations, type Locale } from '@/i18n'

export const prerender = false

const user = Astro.locals.user
const session = Astro.locals.session

// Get current locale from URL (en is default, no prefix)
const locale = (Astro.currentLocale || 'en') as Locale
const t = getTranslations(locale)

let profileCompleted = true
if (session && user) {
  const createdAt = new Date(user.createdAt).getTime()
  const updatedAt = new Date(user.updatedAt).getTime()
  const THRESHOLD_MS = 5000 // 5 seconds
  profileCompleted = (updatedAt - createdAt) > THRESHOLD_MS
  
  if (!profileCompleted) {
    return Astro.redirect('/create-profile')
  }
}
---

<Layout title={session ? t.home.captureTitle : t.home.title} showNavbar={!!session}>
  {session && user ? (
    <main class="max-w-5xl mx-auto w-full px-4 py-8">
      <CaptureImage client:load locale={locale} />
    </main>
  ) : (
    <div class="min-h-screen flex flex-col items-center gap-6 justify-center px-6">
      {/* Language Switcher - positioned at top right */}
      <div class="fixed top-6 right-6 z-50">
        <LanguageSwitcher client:load />
      </div>
      
      <Logo />
      <div class="flex flex-col items-center gap-2">
        <h1 class="text-4xl font-semibold">{t.common.appName}</h1>
        <p class="text-foreground-subtle text-xl mb-4">
          {t.home.tagline}
        </p>
        <p class="text-center max-w-[50ch] md:max-w-[46ch]">
          {t.home.description}
        </p>
      </div>

      <GoogleSignInButton client:idle locale={locale} />

      <IndexCards />
    </div>
  )}
</Layout>
